---
import { Image } from "astro:assets";
import myLogo from "@assets/logo.opti.webp";

const navItems = [
  { name: 'Home', url: '/' },
  { name: 'Services', url: '/services' },
  { name: 'Projects', url: '/projects' },
  { name: 'About', url: '/about' },
  { name: 'Contact', url: '/contact' },
];

const currentPath = Astro.url.pathname;
---

<nav class="fixed top-0 z-30 w-full bg-primary shadow-md">
  <div class="container mx-auto flex items-center justify-between px-4 py-4">

    <!-- Logo + Company Name -->
    <div class="flex items-center gap-2">
      <a href="/">
        <Image
          src={myLogo}
          format="avif"
          width={160}
          height={112}
          alt="Company logo"
          class="h-12 w-auto"
        />
      </a>
      <span class="hidden text-lg font-bold text-white whitespace-nowrap md:block">
        The Professionals Window &amp; Eaves Cleaning Ltd.
      </span>
    </div>

    <!-- Desktop Nav Links -->
    <ul class="hidden items-center gap-8 text-sm font-bold uppercase md:flex text-base-100">
      {navItems.map(item => (
        <li>
          <a
            href={item.url}
            class={`transition-colors hover:text-accent ${currentPath === item.url ? 'text-accent' : ''}`}
          >
            {item.name}
          </a>
        </li>
      ))}
      <li>
        <a href="/contact" class="btn btn-accent btn-sm rounded-full font-bold uppercase tracking-wide">
          Get a Quote
        </a>
      </li>
    </ul>

    <!-- Mobile Hamburger (3 clean lines, no X animation) -->
    <button id="hamburger" class="cursor-pointer p-2 md:hidden" aria-label="Open menu">
      <div class="space-y-1.5">
        <div class="h-0.5 w-7 bg-white"></div>
        <div class="h-0.5 w-7 bg-white"></div>
        <div class="h-0.5 w-7 bg-white"></div>
      </div>
    </button>
  </div>
</nav>

<!-- Backdrop -->
<div
  id="backdrop"
  class="fixed inset-0 z-40 bg-black/60 opacity-0 pointer-events-none transition-opacity duration-300"
  aria-hidden="true"
></div>

<!-- Side Drawer -->
<div
  id="drawer"
  class="fixed right-0 top-0 z-50 flex h-full w-3/4 max-w-sm translate-x-full flex-col bg-secondary shadow-2xl transition-transform duration-300 ease-in-out"
>
  <!-- Drawer Header -->
  <div class="flex items-center justify-between border-b border-white/10 px-6 py-5">
    <span class="text-sm font-bold uppercase tracking-widest text-accent">Menu</span>
    <button id="close-drawer" class="text-white hover:text-accent transition-colors" aria-label="Close menu">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Nav Links -->
  <ul class="flex-1 overflow-y-auto">
    {navItems.map(item => (
      <li class="border-b border-white/10">
        <a
          href={item.url}
          class={`block px-6 py-4 text-lg font-semibold transition-colors hover:text-accent ${currentPath === item.url ? 'text-accent' : 'text-white'}`}
        >
          {item.name}
        </a>
      </li>
    ))}
  </ul>

  <!-- Drawer Footer -->
  <div class="space-y-4 border-t border-white/10 px-6 py-6">
    <a href="tel:4164645542" class="flex items-center gap-2 font-semibold text-white transition-colors hover:text-accent">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 8V5z" />
      </svg>
      416-464-5542
    </a>
    <a href="/contact" class="btn btn-accent w-full rounded-full font-bold uppercase tracking-wide">
      Get a Quote
    </a>
  </div>
</div>

<script>
  const hamburger = document.getElementById('hamburger');
  const backdrop = document.getElementById('backdrop');
  const drawer = document.getElementById('drawer');
  const closeDrawer = document.getElementById('close-drawer');

  function openMenu() {
    drawer?.classList.remove('translate-x-full');
    backdrop?.classList.remove('opacity-0', 'pointer-events-none');
    backdrop?.classList.add('opacity-100');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    drawer?.classList.add('translate-x-full');
    backdrop?.classList.add('opacity-0', 'pointer-events-none');
    backdrop?.classList.remove('opacity-100');
    document.body.style.overflow = '';
  }

  hamburger?.addEventListener('click', openMenu);
  closeDrawer?.addEventListener('click', closeMenu);
  backdrop?.addEventListener('click', closeMenu);
</script>
