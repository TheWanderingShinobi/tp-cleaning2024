---
// 1. Import the Image component and your image file
import { Image } from 'astro:assets'
import heroImage from '../assets/toronto-window-cleaning-bg.webp'
---

<section>
	<div
		class="relative min-h-[85vh] overflow-hidden bg-cover bg-no-repeat"
		style="background-position: 50% center;"
	>
		{
			/* 2. This is the corrected <Image> component.
      - We add `width` and `height` of the ORIGINAL source image.
      - We add `widths` to create responsive versions.
      - We add `sizes="100vw"` because it's a full-width hero.
      - `fetchpriority="high"` remains to tell the browser to load it ASAP.
    */
		}
		<Image
			src={heroImage}
			alt="Toronto window cleaning background"
			class="absolute inset-0 h-full w-full object-cover"
			width={844}
			height={1024}
			widths={[480, 844, 1200]}
			sizes="100vw"
			quality={85}
			fetchpriority="high"
		/>

		<div
			class="absolute inset-0 bg-black/75"
		>
			<div class="flex h-full min-h-[85vh] items-center justify-center">
				<div class="px-6 text-center text-white md:px-12">
					<h3 class="pb-4 text-sm uppercase tracking-widest text-accent opacity-80">
						Quality Service • Value for your money • Affordable Price
					</h3>
					<h1 class="mb-12 text-5xl font-extrabold leading-tight md:text-6xl">
						Rejuvenate the look of <br /><span>your home today</span>
					</h1>
					<a role="button" href="contact" class="btn btn-lg btn-accent rounded-full px-10 uppercase tracking-wider font-bold hover:brightness-90">Get Started</a>
				</div>
			</div>
		</div>
	</div>
</section>
