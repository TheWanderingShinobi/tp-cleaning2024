---
import { Image } from 'astro:assets'

import imgEaves from '@assets/toronto-eavestrough-cleaning.webp'
import imgPower from '@assets/toronto-power-washing.webp'
import imgWindow from '@assets/toronto-window-cleaning.webp'

const services = [
  {
    title: 'Eavestrough Cleaning',
    icon: 'fa-solid fa-droplet',
    img: imgEaves,
    alt: 'Before and after eavestrough cleaning',
    description: 'Have you been noticing more leaves, dirt, and debris accumulating in your gutters? Maybe there\'s a build-up of water that can\'t seem to drain properly? Gutter cleaning is the perfect solution for clearing out all the mess and restoring your gutters to their former glory.',
    href: '/eavestrough-cleaning',
    label: 'Eavestrough Cleaning',
  },
  {
    title: 'Power Washing',
    icon: 'fa-solid fa-spray-can-sparkles',
    img: imgPower,
    alt: 'Before and after power washing',
    description: 'Our pressure washing service is the perfect way to get your home clean and free of stains. With our experienced professionals, you\'ll get the job done quickly and efficiently, leaving your home looking its best. Combine eavestrough cleaning and a power wash to save.',
    href: '/power-washing',
    label: 'Power Washing',
  },
  {
    title: 'Window Cleaning',
    icon: 'fa-solid fa-window-maximize',
    img: imgWindow,
    alt: 'Before and after window cleaning',
    description: 'Looking for a reliable and affordable window cleaning service? We offer a wide range of services, including regular window cleaning and spring/fall window cleaning. We also offer special discounts for job referrals. Give us a call today to schedule your free consultation.',
    href: '/window-cleaning',
    label: 'Window Cleaning',
  },
]
---

<section class="py-16 px-4 md:px-8">
  <h2 class="text-3xl font-bold text-center text-white mb-12">HOW CAN WE HELP YOU TODAY?</h2>

  <div class="container mx-auto grid grid-cols-1 md:grid-cols-3 gap-8">
    {services.map(service => (
      <div class="card bg-base-200 rounded-2xl shadow-lg overflow-hidden transition-all duration-300 hover:-translate-y-2 hover:shadow-2xl">
        <figure>
          <Image
            src={service.img}
            format="avif"
            alt={service.alt}
            width={600}
            height={224}
            class="h-56 w-full object-cover"
          />
        </figure>
        <div class="card-body p-6 flex flex-col">
          <i class={`${service.icon} text-primary text-3xl mb-3`}></i>
          <h3 class="card-title text-lg font-bold text-primary mb-2">{service.title}</h3>
          <p class="text-base leading-relaxed opacity-80 text-primary line-clamp-4 flex-1">
            {service.description}
          </p>
          <div class="mt-6">
            <a
              role="button"
              href={service.href}
              class="btn btn-accent rounded-full uppercase tracking-wide font-semibold"
            >
              {service.label}
            </a>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>
