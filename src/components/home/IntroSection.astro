---
import { Image } from "astro:assets";
import beforeAfter from "@assets/toronto-window-cleaning_1.webp";
import { introContent } from "@data/homeContent.js";
---

<section class="py-16 px-4 md:px-8" aria-label="Introduction section">
  <div class="container mx-auto text-center">

    <!-- Heading -->
    <h2 class="text-3xl font-bold text-white md:text-4xl mb-4">
      {introContent.heading}
    </h2>

    <!-- Subheading -->
    <p class="text-lg text-accent italic mb-8">
      {introContent.subtext} <span class="font-bold not-italic">The Professionals.</span>
    </p>

    <!-- Feature checkmarks -->
    <div class="flex flex-col sm:flex-row justify-center gap-8 mb-10">
      {introContent.features.map((feature) => (
        <div class="flex items-center justify-center gap-2">
          <i class="fa-solid fa-circle-check text-accent text-2xl"></i>
          <span class="font-bold text-white text-base">{feature}</span>
        </div>
      ))}
    </div>

    <!-- Body text -->
    <p class="max-w-3xl mx-auto text-base leading-relaxed text-gray-300 mb-10">
      {introContent.bodyText}
    </p>

    <!-- Before/after image -->
    <div class="max-w-lg mx-auto mt-8 rounded-2xl shadow-lg overflow-hidden">
      <Image
        src={beforeAfter}
        format="avif"
        width={640}
        height={640}
        alt="Before and after window cleaning"
        class="w-full h-auto"
      />
    </div>

  </div>
</section>
