---
---

<section class="bg-accent py-16 px-4">
  <div class="mx-auto flex max-w-5xl flex-col items-center justify-between gap-10 md:flex-row md:gap-8 px-4 md:px-8">

    <!-- Left: Headline & subtext -->
    <div class="text-center md:text-left">
      <p class="mb-1 text-sm font-bold uppercase tracking-widest text-primary/60">Limited Time Offer</p>
      <h2 class="mb-3 text-2xl font-extrabold text-primary md:text-3xl leading-tight">
        Spring Special — Save on<br class="hidden md:block" /> Your Next Cleaning
      </h2>
      <p class="text-lg text-primary/80">
        Mention this code when you book to redeem your discount.
      </p>
      <div class="mt-6 flex flex-col sm:flex-row gap-4 items-center md:items-start">
        <a
          href="/contact"
          class="btn btn-primary btn-lg rounded-full uppercase tracking-wide font-bold"
        >
          Book Now
        </a>
        <a
          href="tel:416-464-5542"
          class="btn btn-outline btn-primary btn-lg rounded-full uppercase tracking-wide font-bold"
        >
          Call Us
        </a>
      </div>
    </div>

    <!-- Right: Promo code coupon -->
    <div class="shrink-0 text-center">
      <p class="mb-3 text-sm font-bold uppercase tracking-widest text-primary/60">Your promo code</p>
      <div class="relative rounded-xl border-2 border-dashed border-primary/30 bg-primary px-10 py-6 shadow-xl">
        <!-- Ticket notch left -->
        <div class="absolute -left-3 top-1/2 h-6 w-6 -translate-y-1/2 rounded-full bg-accent"></div>
        <!-- Ticket notch right -->
        <div class="absolute -right-3 top-1/2 h-6 w-6 -translate-y-1/2 rounded-full bg-accent"></div>

        <p class="font-mono text-3xl font-bold tracking-widest text-accent md:text-4xl">
          SPRING2026
        </p>
      </div>
      <p class="mt-3 text-xs text-primary/50 uppercase tracking-wide">Valid on all services · 2026 season</p>
    </div>

  </div>
</section>
