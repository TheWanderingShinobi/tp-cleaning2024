---
import { Image } from "astro:assets"
import faceAnna from "../assets/anna.webp"
import faceAngelina from "../assets/angelina.webp"
import faceDoug from "../assets/doug.webp"

const testimonials = [
  {
    name: 'Anna',
    source: 'Google',
    img: faceAnna,
    alt: 'Anna',
    quote: 'I would recommend The Professional Window and Eaves Cleaners without any hesitation. They did a great job on my windows. They take their time and do a thorough job. They clean up after themselves and are responsive to customer input. Customer satisfaction is definitely first on their list. I would definitely continue to hire them for any work.',
  },
  {
    name: 'Angelina',
    source: 'Bark',
    img: faceAngelina,
    alt: 'Angelina',
    quote: 'The service was great! Punctual, great work ethic, and fast! Very reasonable prices.',
  },
  {
    name: 'Doug',
    source: 'Homestars',
    img: faceDoug,
    alt: 'Doug',
    quote: "Did a fantastic job with both gutters and exterior windows, and very prompt service. It's a large house, and they finished in a day. Great work.",
  },
]
---

<div class="bg-secondary">
  <section class="py-16 px-4 md:px-8">
    <h2 class="text-3xl font-bold text-center text-white mb-2">Our Satisfied Clients</h2>
    <p class="text-center text-base-100 mb-12 text-lg">Here's what they have to say</p>

    <div class="container mx-auto grid grid-cols-1 md:grid-cols-3 gap-8">
      {testimonials.map(t => (
        <div class="bg-secondary rounded-2xl shadow-lg p-8 flex flex-col">

          <!-- Decorative quote icon -->
          <i class="fa-solid fa-quote-left text-4xl text-accent opacity-30 mb-4"></i>

          <!-- Star rating -->
          <div class="flex gap-1 mb-4">
            {Array(5).fill(null).map(() => (
              <i class="fa-solid fa-star text-yellow-400"></i>
            ))}
          </div>

          <!-- Quote text -->
          <p class="text-base leading-relaxed italic text-gray-300 flex-1">
            {t.quote}
          </p>

          <!-- Reviewer info -->
          <div class="mt-6 pt-6 border-t border-white/10 flex items-center gap-4">
            <Image
              src={t.img}
              format="avif"
              width={64}
              height={64}
              alt={t.alt}
              class="w-16 h-16 rounded-full ring-2 ring-accent object-cover shrink-0"
            />
            <div>
              <span class="font-bold text-lg text-white">{t.name}</span>
              <span class="badge badge-accent badge-sm ml-2">{t.source}</span>
            </div>
          </div>

        </div>
      ))}
    </div>
  </section>
</div>
