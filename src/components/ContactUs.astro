---
import { Image } from "astro:assets"
import imgContact from "@assets/scarborough-eavestrough-cleaning-logo.webp"
---

<section class="py-16 px-4">
  <div class="container mx-auto grid lg:grid-cols-2 gap-12 items-start">

    <!-- Left: Form -->
    <div class="bg-secondary rounded-2xl shadow-lg p-8 max-w-2xl mx-auto w-full">
      <h2 class="text-3xl font-bold text-center text-white mb-8">
        Are You Ready to Hire <span class="text-accent">The Professionals?</span>
      </h2>

      <form method="POST" action="https://api.web3forms.com/submit">
        <input type="hidden" name="access_key" value="a4e44ece-4a17-415f-84a1-73716b35b94a" />
        <input type="checkbox" name="botcheck" style="display:none" />

        <div class="mb-4">
          <label for="nameFull" class="block text-sm font-semibold text-gray-300 mb-1">Full Name</label>
          <input
            type="text"
            id="nameFull"
            name="nameFull"
            placeholder="Full Name"
            required
            class="input input-bordered w-full bg-primary text-white focus:border-accent"
          />
        </div>

        <div class="mb-4">
          <label for="telephone" class="block text-sm font-semibold text-gray-300 mb-1">Telephone</label>
          <input
            type="tel"
            id="telephone"
            name="telephone"
            placeholder="Telephone"
            required
            class="input input-bordered w-full bg-primary text-white focus:border-accent"
          />
        </div>

        <div class="mb-4">
          <label for="email" class="block text-sm font-semibold text-gray-300 mb-1">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            placeholder="Email"
            required
            class="input input-bordered w-full bg-primary text-white focus:border-accent"
          />
        </div>

        <div class="mb-4">
          <label for="message" class="block text-sm font-semibold text-gray-300 mb-1">Message</label>
          <textarea
            id="message"
            name="message"
            placeholder="Message"
            required
            class="textarea textarea-bordered w-full bg-primary text-white focus:border-accent min-h-[120px]"
          ></textarea>
        </div>

        <button type="submit" class="btn btn-accent rounded-full w-full text-lg font-bold uppercase tracking-wide mt-4">
          Send Message
        </button>
      </form>
    </div>

    <!-- Right: Logo + contact info -->
    <div class="flex flex-col items-center lg:items-start gap-6 text-gray-300">
      <div class="flex justify-center w-full">
        <Image
          src={imgContact}
          format="avif"
          width={320}
          height={320}
          alt="Company logo"
          class="rounded-2xl shadow-lg object-cover"
        />
      </div>

      <p class="text-gray-300 leading-relaxed text-center lg:text-left">
        At The Professionals Window and Eaves Cleaning Ltd., we pride ourselves on providing
        high-quality cleaning services that our clients can trust. Our motto: <em>"When you want a
        job done right, call The Professionals."</em> Get in touch today to learn more.
      </p>

      <div class="space-y-4 w-full">
        <p class="text-accent font-bold uppercase tracking-widest text-sm">Contact</p>

        <p class="flex items-start gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5 shrink-0 mt-0.5 text-accent">
            <path d="M11.47 3.84a.75.75 0 011.06 0l8.69 8.69a.75.75 0 101.06-1.06l-8.689-8.69a2.25 2.25 0 00-3.182 0l-8.69 8.69a.75.75 0 001.061 1.06l8.69-8.69z"></path>
            <path d="M12 5.432l8.159 8.159c.03.03.06.058.091.086v6.198c0 1.035-.84 1.875-1.875 1.875H15a.75.75 0 01-.75-.75v-4.5a.75.75 0 00-.75-.75h-3a.75.75 0 00-.75.75V21a.75.75 0 01-.75.75H5.625a1.875 1.875 0 01-1.875-1.875v-6.198a2.29 2.29 0 00.091-.086L12 5.43z"></path>
          </svg>
          1108 - 250 Consumers Rd Mailbox: #166, North York, ON M2J 4V6
        </p>

        <p class="flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5 shrink-0 text-accent">
            <path d="M1.5 8.67v8.58a3 3 0 003 3h15a3 3 0 003-3V8.67l-8.928 5.493a3 3 0 01-3.144 0L1.5 8.67z"></path>
            <path d="M22.5 6.908V6.75a3 3 0 00-3-3h-15a3 3 0 00-3 3v.158l9.714 5.978a1.5 1.5 0 001.572 0L22.5 6.908z"></path>
          </svg>
          admin@theprofessionalswindowcleaning.com
        </p>

        <p class="flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5 shrink-0 text-accent">
            <path fill-rule="evenodd" d="M1.5 4.5a3 3 0 013-3h1.372c.86 0 1.61.586 1.819 1.42l1.105 4.423a1.875 1.875 0 01-.694 1.955l-1.293.97c-.135.101-.164.249-.126.352a11.285 11.285 0 006.697 6.697c.103.038.25.009.352-.126l.97-1.293a1.875 1.875 0 011.955-.694l4.423 1.105c.834.209 1.42.959 1.42 1.82V19.5a3 3 0 01-3 3h-2.25C8.552 22.5 1.5 15.448 1.5 6.75V4.5z" clip-rule="evenodd"></path>
          </svg>
          <a href="tel:4164645542" class="hover:text-accent transition-colors">(416) 464-5542</a>
        </p>
      </div>
    </div>

  </div>
</section>
